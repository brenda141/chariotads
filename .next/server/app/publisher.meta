{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/publisher/layout,_N_T_/publisher/page,_N_T_/publisher"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/publisher/__PAGE__",
    "/publisher",
    "/_index",
    "/_head"
  ]
}
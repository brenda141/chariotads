{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/advertiser/layout,_N_T_/advertiser/page,_N_T_/advertiser"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/advertiser/__PAGE__",
    "/advertiser",
    "/_index",
    "/_head"
  ]
}
{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/targeting/layout,_N_T_/targeting/page,_N_T_/targeting"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/targeting/__PAGE__",
    "/targeting",
    "/_index",
    "/_head"
  ]
}